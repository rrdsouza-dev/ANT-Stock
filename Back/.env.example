# ================================================================
# ANT STOCK — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA versione o arquivo .env no git.
# ================================================================

APP_NAME=ANT Stock API
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
API_PREFIX=/api/v1

# ── Banco de dados ───────────────────────────────────────────────
# Use a connection string do Supabase em modo SESSION (porta 5432).
# Acesse: Supabase → Project Settings → Database → Connection string → URI
# Selecione "Session mode" (não Transaction/6543) para compatibilidade com SQLAlchemy async.
DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?ssl=require

# ── Supabase ─────────────────────────────────────────────────────
# Acesse: Supabase → Project Settings → API
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=cole-a-anon-public-key-aqui
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui-APENAS-no-backend

# ── JWT ──────────────────────────────────────────────────────────
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-esta-chave-por-uma-string-longa-e-aleatoria
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS — Domínios permitidos ───────────────────────────────────
# Em produção, coloque APENAS o seu domínio real.
CORS_ORIGINS=["https://seudominio.com.br","https://www.seudominio.com.br"]

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_ATTEMPTS=8
RATE_LIMIT_BLOCK_SECONDS=120

# ── Redis/Celery (opcional, pode deixar em branco para MVP) ──────
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
