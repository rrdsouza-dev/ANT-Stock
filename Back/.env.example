# ================================================================
# ANT STOCK — Variáveis de Ambiente
# Copie para .env e preencha com seus dados reais.
# NUNCA versione o .env no git.
# ================================================================

APP_NAME=ANT Stock API
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
API_PREFIX=/api/v1

# ── Banco de dados ───────────────────────────────────────────────
#
# ⚠️  USE O POOLER (Session mode) — NÃO a URL direta do banco.
#
# Como encontrar:
#   Supabase → Project Settings → Database → Connection Pooling
#   → Modo: Session → copie a URI
#
# Formato correto:
#   postgresql+asyncpg://postgres.SEU_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
#
# ❌ ERRADO (URL direta — recusa conexão de IPs externos):
#   postgresql+asyncpg://postgres:senha@db.xxxx.supabase.co:5432/postgres
#
# ✅ CERTO (Pooler Session mode):
#   postgresql+asyncpg://postgres.abcdef:MinhaSenh4@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
#
# Se a senha tiver caracteres especiais, faça URL-encode:
#   # → %23    @ → %40    ! → %21    $ → %24
#
DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ── Supabase ─────────────────────────────────────────────────────
# Supabase → Project Settings → API
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=cole-a-anon-public-key-aqui
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui-APENAS-no-backend

# ── JWT ──────────────────────────────────────────────────────────
# Gere: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=troque-esta-chave-por-uma-string-longa-e-aleatoria
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["https://seudominio.com.br","https://www.seudominio.com.br"]

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_ATTEMPTS=8
RATE_LIMIT_BLOCK_SECONDS=120
